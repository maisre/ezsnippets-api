PORT=3000
NODE_ENV=development
DATABASE_URL=mongodb://localhost:27017/ez-snippet
JWT_SECRET=your-secret-key
PADDLE_API_KEY=your_paddle_api_key_here
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret_here
PADDLE_ENVIRONMENT=sandbox
OPENAI_API_KEY=sk-your-openai-api-key-here
AWS_ACCESS_KEY=your-aws-access-key
AWS_ACCESS_SECRET=your-aws-access-secret
EMAIL_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/your-account-id/your-email-queue
# Image uploads. Set AWS_ENDPOINT_URL to point at LocalStack — doing so also
# switches the S3 client to path-style addressing, which LocalStack requires for
# presigned POST uploads. ASSETS_CDN_URL is the public base URL images are served
# from; in deployed envs it's the assets CloudFront domain.
# AWS_ENDPOINT_URL=http://localhost:4566
# ASSETS_CDN_URL=http://localhost:4566/ez-snippet-assets
ASSETS_BUCKET=ez-snippet-assets
# Stock photo search, used by POST /pages/:id/customize-images. Moved here from
# ez-view so query derivation (OpenAI) and search live in one place.
SHUTTERSTOCK_API_TOKEN=your-shutterstock-api-token
# Override all plan limits for local testing (format: maxPages,maxLayouts,maxSnippets)
# PLAN_LIMITS_OVERRIDE=2,1,10

# Sentry error reporting
# DSN can stay set permanently — in development, reporting stays OFF until you
# set SENTRY_ENABLE_DEV=true. Staging/prod set SENTRY_ENVIRONMENT via the deploy
# and report whenever a DSN is present.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# SENTRY_ENABLE_DEV=true